# Copy to .env.local and fill in real values. Do not commit .env.local.

# Required for /admin and /api/admin/* (MongoDB connection string)
MONGODB_URI=mongodb://127.0.0.1:27017/rajasthan_pipe_traders

# Admin UI + /api/admin/* — gate with this password (httpOnly session cookie)

# Express API base URL for Cloudinary media routes (GET/POST /api/media, etc.)
# Example: http://localhost:5000 — see docs/Cloudenary_MEDIA_API.md
MEDIA_API_URL=http://localhost:5000
